# 参考 Hydro OJ 的 .npmrc 配置，减少 npm install 噪声与本地开发的意外失败
# - strict-peer-dependencies=false: 避免.peer deps 冲突导致 install 失败（多个 Next 插件对 React 版本要求不一）
# - fund=false: 关闭 "0 packages are looking for funding" 提示
# - audit=false: 关闭本地 install 后的安全审计（CI 已有专门步骤）
# - save-exact=false: 保持 ^ 范围版本，便于补丁自动升级
strict-peer-dependencies=false
fund=false
audit=false
save-exact=false
