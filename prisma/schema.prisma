
// Prisma Schema for 大山 OJ with MongoDB
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  username      String    @unique
  email         String    @unique
  password      String
  nickname      String?
  avatar        String?
  bio           String?
  rating        Int       @default(1500)
  solvedCount   Int       @default(0) // 解题数
  rank          String    @default("新手")
  color         String    @default("#808080")
  role          String    @default("STUDENT") // SYSTEM_ADMIN, ADMIN, TEACHER, STUDENT（唯一真相源，详见 docs/ROLE_SYSTEM.md）
  isBanned      Boolean   @default(false)
  tokenVersion  Int       @default(0) // JWT 吊销版本号：修改密码/封禁时递增，使旧 Token 失效
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 游戏化字段（Phase 1 预留，Phase 2+ 启用）
  exp             Int       @default(0)     // 累计经验值
  level           Int       @default(1)     // 当前等级
  coins           Int       @default(0)     // 金币余额
  title           String?                   // 用户称号（来自成就/商城）
  dailyCoinEarned Int       @default(0)     // 当日已获得金币（每日 0 点重置）
  dailyCoinResetAt DateTime?                // 每日金币计数器重置时间
  lastAcDate      DateTime?                 // 最后一次 AC 日期（用于每日首 AC bonus）
  newbieBonusUsed Int       @default(0)     // 新手保护期已用次数（上限 10）
  lastRating      Int       @default(1500)  // 上次 rating，用于进步奖励对比

  // 关系
  submissions   Submission[]
  problems      Problem[]
  contests      Contest[]
  classes       ClassMember[]
  comments      Comment[]
  blogs         Blog[]
  solutions     Solution[]
  solutionViews SolutionView[]
  solutionLikes SolutionLike[]
  achievements  UserAchievement[]
  favorites     Favorite[]
  classNotes    ClassNote[]
  notifications Notification[]

  // 邀请关系
  sentDirectInvites     ClassDirectInvite[] @relation("InviterRelation")
  receivedDirectInvites ClassDirectInvite[] @relation("InviteeRelation")

  // 申请关系
  joinRequests          ClassJoinRequest[] @relation("JoinRequestUser")
  reviewedRequests      ClassJoinRequest[] @relation("JoinRequestReviewer")

  // 竞赛参与
  contestParticipations ContestParticipant[]

  // 头像历史
  avatarHistory AvatarHistory[]

  // AI生成记录
  aiGenerations AiGenerationLog[]

  // AI 偏好
  aiPreferences UserAiPreference[]

  // 题单
  authoredTrainings    Training[]           @relation("TrainingAuthor")
  trainingEnrollments  TrainingEnrollment[]

  systemAnnouncements SystemAnnouncement[]

  // 游戏化关系（Phase 1 预留）
  coinTransactions       CoinTransaction[]
  purchases              PurchaseTransaction[]
  problemProgress        ClassAssignmentProblemProgress[]
  completionRewardLogs   AssignmentCompletionRewardLog[]
  contestRankingRewards  ContestRankingRewardLog[]
  contestCompletionRewards ContestCompletionRewardLog[]
  rewardLogs             RewardGrantLog[]
  achievementProgress    AchievementProgress[]
  createdShopItems       ShopItem[]              @relation("ShopItemCreator")
  rewardConfigChanges    RewardConfigChangeLog[]

  @@index([rating])
  @@index([solvedCount])
  @@index([role])
}

// 头像历史记录
model AvatarHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  url       String   // 头像URL
  filename  String?  // 原始文件名
  size      Int?     // 文件大小
  createdAt DateTime @default(now())
  
  @@index([userId])
}

// 题目模型
model Problem {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  problemNumber String?     @unique  // 题目编号，如 "P1001"（可为空）
  title         String
  description   String
  input         String
  output        String
  samples       Json
  hint          String?
  source        String?
  difficulty    String
  tags          String[]
  timeLimit     Int         @default(1000)
  memoryLimit   Int         @default(128)
  comparisonMode String     @default("default") // 输出比较模式：default/strict/ignore-spaces/real-number
  realPrecision Int         @default(3) // 浮点数比较精度（小数位数），仅 real-number 模式生效
  isPublic      Boolean     @default(false)
  visibility    String      @default("public") // 'public', 'private', 'contest'
  totalSubmit   Int         @default(0)
  totalAccepted Int         @default(0)
  authorId      String      @db.ObjectId
  author        User        @relation(fields: [authorId], references: [id])
  classId       String?     @db.ObjectId // 关联班级ID (如果是班级私有题目)
  
  // AI生成相关字段
  isAiGenerated Boolean     @default(false)
  aiStatus      String      @default("MANUAL_CREATED") // MANUAL_CREATED, AI_ASSISTED, AI_GENERATED
  aiPrompt      String?     // 生成该题目的原始提示词

  // 标程（用于验证数据）
  stdCode       String?
  stdLang       String?

  // 游戏化奖励配置（Phase 1 预留，Phase 2+ 启用；null = 按难度默认值）
  expReward        Int?     // 自定义经验奖励
  coinReward       Int?     // 自定义金币奖励
  timeThresholds   Json?    // 自定义用时阈值 { gold, silver, bronze } (ms)

  verificationLogs VerificationLog[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  submissions   Submission[]
  testCases     TestCase[]
  solutions     Solution[]
  contestProblems ContestProblem[]
  trainingProblems TrainingProblem[]
  favorites     Favorite[]
  assignmentProblems ClassAssignmentProblem[]
  problemProgress    ClassAssignmentProblemProgress[]

  @@index([isPublic])
  @@index([difficulty])
  @@index([visibility])
  @@index([authorId])
  @@index([classId])
}

// 测试用例
model TestCase {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  problemId   String   @db.ObjectId
  problem     Problem  @relation(fields: [problemId], references: [id])
  input       String
  output      String
  isSample    Boolean  @default(false)
  score       Int      @default(10)
  timeLimit   Int?     // 单测点时间限制覆盖（null=使用题目默认）
  memoryLimit Int?     // 单测点内存限制覆盖（null=使用题目默认）
  orderIndex  Int
  createdAt   DateTime @default(now())

  @@index([problemId])
}

// 提交记录
model Submission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  problemId   String   @db.ObjectId
  problem     Problem? @relation(fields: [problemId], references: [id])  // ✅ 设置为可选，防止题目被删除导致查询失败
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  contestId   String?  @db.ObjectId
  contest     Contest? @relation(fields: [contestId], references: [id])
  language    String
  code        String
  status      String
  score       Int      @default(0)
  time        Int      @default(0)
  memory      Int      @default(0)
  passedTests Int      @default(0)
  totalTests  Int      @default(0)
  message     String?
  testResults Json?
  assignmentSubmissionId String? @db.ObjectId
  submittedAt DateTime @default(now())
  
  @@index([problemId])
  @@index([userId])
  @@index([contestId])
  @@index([status])
  @@index([submittedAt])
  @@index([problemId, userId])
  @@index([problemId, status])
  @@index([userId, submittedAt])
  @@index([userId, status])
}

// 竞赛模型
model Contest {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  type        String
  startTime   DateTime
  endTime     DateTime
  duration    Int
  isPublic    Boolean     @default(false)
  password    String?
  authorId    String      @db.ObjectId
  author      User        @relation(fields: [authorId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // 游戏化奖励配置（Phase 1 预留，Phase 2+ 启用）
  unifiedExpReward  Int?    // 竞赛统一经验奖励（覆盖题目/难度默认）
  unifiedCoinReward Int?    // 竞赛统一金币奖励
  completionTiers   Json?   // 完成度奖励层次 [{ minSolved, expReward, coinReward }]
  rankingRewards    Json?   // 排名奖励层次 [{ maxRank, expReward, coinReward }]

  problems    ContestProblem[]
  submissions Submission[]
  participants ContestParticipant[]

  // 游戏化关系（Phase 1 预留）
  rankingRewardLogs     ContestRankingRewardLog[]
  completionRewardLogs  ContestCompletionRewardLog[]

  @@index([isPublic])
  @@index([startTime])
  @@index([endTime])
  @@index([authorId])
  @@index([type])
}

// 竞赛题目
model ContestProblem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  contestId  String   @db.ObjectId
  contest    Contest  @relation(fields: [contestId], references: [id])
  problemId  String   @db.ObjectId
  problem    Problem  @relation(fields: [problemId], references: [id])
  orderIndex Int
  score      Int      @default(100)

  // 游戏化奖励覆盖（Phase 1 预留，Phase 2+ 启用；null = 按竞赛统一/题目/难度默认）
  expReward  Int?
  coinReward Int?

  @@index([contestId])
}

// 竞赛参与者
model ContestParticipant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  contestId String   @db.ObjectId
  contest   Contest  @relation(fields: [contestId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  score     Int      @default(0)
  rank      Int      @default(0)
  penalty   Int      @default(0)
  joinedAt  DateTime @default(now())

  @@unique([contestId, userId]) // 确保同一用户在同一竞赛中只有一条参与记录
  @@index([contestId, score])
}

// 班级
model Class {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String       @unique
  description String?
  announcement String?
  avatar      String?
  isPublic    Boolean      @default(true)
  maxMembers  Int          @default(50)  // 最大成员数
  ownerId     String       @db.ObjectId  // 班级创建者（班主任）
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members     ClassMember[]
  assignments ClassAssignment[]
  notes       ClassNote[]
  directInvites ClassDirectInvite[]
  trainings   Training[]
}

// 班级成员
model ClassMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  classId   String   @db.ObjectId
  class     Class    @relation(fields: [classId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  role      String   // owner | assistant | student
  remark    String?  // 成员备注

  // 细粒度权限控制
  permissions Json?    @default("{\"canViewProblems\":true,\"canSubmit\":true,\"canViewNotes\":true,\"canCreateNotes\":false,\"canManageAssignments\":false,\"canInviteMembers\":false}")

  // 活动统计
  lastActiveAt DateTime? // 最后活动时间
  joinedAt     DateTime  @default(now())

  @@unique([classId, userId])  // 确保用户在班级中唯一
  @@index([classId, role])     // 优化按角色查询
  @@index([classId, lastActiveAt]) // 优化按活动度查询
}

// 班级作业
model ClassAssignment {
  id          String                    @id @default(auto()) @map("_id") @db.ObjectId
  classId     String                    @db.ObjectId
  class       Class                     @relation(fields: [classId], references: [id])
  title       String
  description String
  problemIds  String[]  @db.ObjectId  // 引用平台公开题库的题目ID列表
  startTime   DateTime?
  endTime     DateTime?
  createdBy   String                    @db.ObjectId
  createdAt   DateTime                  @default(now())

  // 游戏化奖励配置（Phase 1 预留，Phase 2+ 启用；null = 按题目/难度默认）
  unifiedExpReward           Int?     // 作业统一经验奖励
  unifiedCoinReward          Int?     // 作业统一金币奖励
  unifiedTimeThresholds      Json?    // 作业统一用时阈值 { gold, silver, bronze } (ms)
  completionTiers            Json?    // 完成度奖励层次 [{ minCompletion, expReward, coinReward }]
  allowLateSubmission        Boolean @default(false) // 是否允许逾期提交
  lateSubmissionRewardRatio  Float    @default(0.5)  // 逾期提交奖励比例

  submissions ClassAssignmentSubmission[]
  problems    ClassAssignmentProblem[]
  problemProgress ClassAssignmentProblemProgress[]
  completionRewardLogs AssignmentCompletionRewardLog[]

  @@index([classId])
}

// 班级作业题目（每题独立配置覆盖作业统一配置，Phase 1 预留）
model ClassAssignmentProblem {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId  String   @db.ObjectId
  assignment    ClassAssignment @relation(fields: [assignmentId], references: [id])
  problemId     String   @db.ObjectId
  problem       Problem  @relation(fields: [problemId], references: [id])
  orderIndex    Int      @default(0)

  // 单题覆盖作业统一配置（null = 按作业统一/题目/难度默认）
  expReward      Int?
  coinReward     Int?
  timeThresholds Json?   // { gold, silver, bronze } (ms)

  @@unique([assignmentId, problemId])
  @@index([assignmentId])
}

// 班级作业提交记录
model ClassAssignmentSubmission {
  id              String                @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId    String                @db.ObjectId
  assignment      ClassAssignment       @relation(fields: [assignmentId], references: [id])
  userId          String                @db.ObjectId
  problemId       String                @db.ObjectId

  // 提交内容
  code            String                // 提交的代码
  language        String                // 编程语言

  // 评测结果
  status          String                // AC, WA, TLE, MLE, RE, CE, SE 等
  score           Int                   @default(0)  // 得分
  time            Int                   @default(0)  // 执行时间（ms）
  memory          Int                   @default(0)  // 内存使用（KB）
  passedTests     Int                   @default(0)  // 通过的测试点数
  totalTests      Int                   @default(0)  // 总测试点数
  message         String?               // 错误信息或编译信息

  // 提交时间信息
  submittedAt     DateTime              @default(now())
  isLate          Boolean               @default(false)  // 是否逾期提交

  // 计时与首次 AC 标记（Phase 1 启用）
  timeElapsedMs   Int                   @default(0)  // 完成用时（ms），由 finalizeTiming 写入
  isFirstAc       Boolean               @default(false)  // 是否为该题在该作业上下文中的首次 AC

  @@index([assignmentId, userId])  // 优化按作业和用户查询
  @@index([assignmentId, problemId])  // 优化按作业和题目查询
  @@index([assignmentId, userId, problemId, submittedAt])  // 优化查询最新提交
}

// 班级笔记
model ClassNote {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  classId     String   @db.ObjectId
  class       Class    @relation(fields: [classId], references: [id])
  title       String
  content     String
  category    String   // 笔记分类
  tags        String[]
  authorId    String   @db.ObjectId
  author      User     @relation(fields: [authorId], references: [id])
  isPublic    Boolean  @default(true)  // 是否对班级成员公开
  views       Int      @default(0)
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([classId])
  @@index([classId, createdAt])
}

// 班级直接邀请（通过用户名邀请）
model ClassDirectInvite {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  classId       String   @db.ObjectId
  class         Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  inviterId     String   @db.ObjectId  // 邀请人ID
  inviter       User     @relation("InviterRelation", fields: [inviterId], references: [id])
  inviteeId     String   @db.ObjectId  // 被邀请人ID
  invitee       User     @relation("InviteeRelation", fields: [inviteeId], references: [id])
  status        String   @default("pending")  // pending | accepted | rejected | expired
  message       String?  // 邀请留言
  expiresAt     DateTime?  // 过期时间
  respondedAt   DateTime?  // 响应时间
  createdAt     DateTime @default(now())

  @@index([classId])
  @@index([inviteeId])
  @@index([inviterId])
  @@unique([classId, inviteeId])  // 同班只能向同一用户发送一次邀请
}

// 班级加入申请
model ClassJoinRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  classId     String   @db.ObjectId
  userId      String   @db.ObjectId  // 申请人ID
  user        User     @relation("JoinRequestUser", fields: [userId], references: [id])
  status      String   @default("pending")  // pending | approved | rejected
  message     String?  // 申请留言
  reviewerId  String?  @db.ObjectId  // 审批人ID
  reviewer    User?    @relation("JoinRequestReviewer", fields: [reviewerId], references: [id])
  reviewedAt  DateTime?  // 审批时间
  createdAt   DateTime @default(now())

  @@index([classId])
  @@index([userId])
  @@unique([classId, userId])  // 同一用户只能向同一班级发送一次申请
}

// 评论（题解等）
model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  solutionId String? @db.ObjectId
  solution  Solution? @relation(fields: [solutionId], references: [id])
  authorId  String   @db.ObjectId
  author    User     @relation(fields: [authorId], references: [id])
  likes     Int      @default(0)
  
  // 嵌套评论
  parentId  String?  @db.ObjectId
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   Comment[] @relation("CommentReplies")
  
  isDeleted Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([solutionId])
  @@index([authorId])
  @@index([solutionId, isDeleted])
  @@index([parentId])
}

// 题解
model Solution {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  problemId     String    @db.ObjectId
  problem       Problem   @relation(fields: [problemId], references: [id])
  authorId      String    @db.ObjectId
  author        User      @relation(fields: [authorId], references: [id])
  title         String
  content       String
  language      String?   // 冗余字段，新代码不再写入，保留兼容旧数据
  // Task 26.6：code 字段保留（向后兼容），存 C++ 版本标程
  code          String?   // 题解配套代码（C++ 标程，向后兼容）
  codeLanguage  String?   // 题解配套代码语言（语义更清晰的别名，与 language 保持同步）
  // Task 26.5：Python 版本标程（多语言标程同步，Task 32）
  // 与 code 字段配合：code 存 C++ 版本，codePython 存 Python 版本（翻译自 C++）
  codePython    String?
  // Task 26.5：题解质量评分（0-5，Task 31 由 scoreSolutionQuality 写入）
  qualityScore  Float?
  views         Int       @default(0)
  likes         Int       @default(0)
  isOfficial    Boolean   @default(false)            // 是否标程题解（置顶展示）
  isAiGenerated Boolean   @default(false)            // 是否 AI 生成
  sourceType    String    @default("USER")           // USER / OFFICIAL / AI_OFFICIAL
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  comments      Comment[]
  viewRecords   SolutionView[]
  likeRecords   SolutionLike[]

  @@index([problemId, isOfficial])
  @@index([problemId, createdAt])
  @@index([authorId])
}

// 题解浏览记录（用于"单账户/IP 只统计一次"的 views 去重）
// viewerKey: 登录用户存 userId；未登录用户存 "ip:userAgentHash" 形式的字符串
model SolutionView {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  solutionId String   @db.ObjectId
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  userId     String?  @db.ObjectId
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  viewerKey  String                                       // userId 或 "ip:userAgentHash"
  viewedAt   DateTime @default(now())

  @@unique([solutionId, viewerKey])
  @@index([solutionId, viewedAt])
}

// 题解点赞记录（用于"单用户只能点一次赞"的 likes 去重）
model SolutionLike {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  solutionId String   @db.ObjectId
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([solutionId, userId])
  @@index([userId])
}

// 博客
model Blog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  authorId  String   @db.ObjectId
  author    User     @relation(fields: [authorId], references: [id])
  tags      String[]
  views     Int      @default(0)
  likes     Int      @default(0)
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([isPublic, createdAt])
}

// 训练计划 / 题单
model Training {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  difficulty    String?           // 题单难度（可选，用于筛选和展示）
  categoryType  String?           // 'official' 官方 | 'contest' 竞赛/考级
  isPublic      Boolean           @default(true)
  status        String            @default("published") // draft / published / archived
  isRecommended Boolean           @default(false)
  tags          String[]
  cover         String?
  joinCount     Int               @default(0)
  viewCount     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // 创建者（管理员/教师）
  authorId      String?           @db.ObjectId
  author        User?             @relation("TrainingAuthor", fields: [authorId], references: [id])

  // 分类（多维度分类，仅作为辅助，categoryType 才是主分类）
  categoryId    String?           @db.ObjectId
  category      TrainingCategory? @relation(fields: [categoryId], references: [id])

  // 班级私有题单：classId 不为空时仅在所属班级可见
  classId       String?           @db.ObjectId
  class         Class?            @relation(fields: [classId], references: [id], onDelete: Cascade)

  problems      TrainingProblem[]
  enrollments   TrainingEnrollment[]

  @@index([isPublic, status])
  @@index([isRecommended, status])
  @@index([categoryId])
  @@index([categoryType])
  @@index([authorId])
  @@index([classId])
}

// 题单分类
model TrainingCategory {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String     @unique
  description String?
  orderIndex  Int        @default(0)
  createdAt   DateTime   @default(now())

  trainings   Training[]
}

// 题单题目关联
model TrainingProblem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  trainingId String   @db.ObjectId
  training   Training @relation(fields: [trainingId], references: [id])
  problemId  String   @db.ObjectId
  problem    Problem  @relation(fields: [problemId], references: [id])
  orderIndex Int
  score      Int      @default(100)
  required   Boolean  @default(true)

  @@unique([trainingId, problemId])
  @@index([trainingId, orderIndex])
}

// 用户加入题单记录
model TrainingEnrollment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  trainingId String   @db.ObjectId
  training   Training @relation(fields: [trainingId], references: [id])
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  joinedAt   DateTime @default(now())

  @@unique([trainingId, userId])
  @@index([userId])
}

// 成就
model Achievement {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  name            String            @unique
  description     String
  icon            String
  condition       String

  // 游戏化扩展（Phase 1 预留，Phase 2+ 启用）
  category        String            @default("learning")  // learning / milestone / diversity / contribution
  rarity          String            @default("common")    // common / rare / epic / legendary
  coinReward      Int               @default(0)           // 解锁时发放金币
  expReward       Int               @default(0)           // 解锁时发放经验
  progressTarget  Int?                                    // 进度目标值（用于进度追踪，null=一次性成就）

  users           UserAchievement[]
  progress        AchievementProgress[]
}

// 用户成就
model UserAchievement {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  userId        String      @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])
  achievementId String      @db.ObjectId
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime    @default(now())

  @@index([userId])
}

// 收藏
model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  problemId String   @db.ObjectId
  problem   Problem  @relation(fields: [problemId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, problemId])
  @@index([problemId])
}

// 通知
model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  content   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// 笔记阅读历史
model NoteReadHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  classId   String   @db.ObjectId
  noteId    String   @db.ObjectId
  userId    String   @db.ObjectId
  readAt    DateTime @default(now())

  @@unique([userId, noteId])
}

// 审计日志
model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId // 可为空（未登录用户）
  action      String   // 例如: "ACCESS_DENIED", "LOGIN_FAILED"
  resource    String   // 例如: "/api/contests/123/problems"
  details     Json?    // 详细信息
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// AI出题记录
model AiGenerationLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  // PENDING / PROCESSING / COMPLETED / FAILED / DISCARDED
  // - DISCARDED：预览-确认工作流中用户丢弃的预览任务（Task 27）
  // - AiGenerationLog.status 是 String 而非 enum（MongoDB 不依赖 DB 层枚举约束）
  status      String
  params      Json     // 请求参数：类型、难度、知识点等（含 mode / batchId / parentLogId / promptHash 等）
  result      Json?    // 生成的题目数据（数组）
  error       String?  // 错误信息
  tokensUsed  Int      @default(0)
  // Task 26.3：预估成本（tokensUsed * model.pricePerMillionTokens / 1_000_000）
  // 注：MongoDB connector 不支持 Decimal 类型，改用 Float?（精度足够用于成本估算）
  estimatedCost Float?
  // Task 26.3 / Task 36：父任务 ID，串联任务链（出题 → 题解、出题失败 → 诊断、批量出题关联）
  parentLogId String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([parentLogId])
}

// AI模型配置（全局思考模型设置存储，被 AiProvider/AiModel 的混合配置方案使用）
// 新模型选择走 AiProvider+AiModel，但 thinking 相关设置仍依赖此表存储
model AiModelConfig {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String?  @db.ObjectId // 关联用户，为空则为全局配置
  scope             String   @default("GLOBAL") // GLOBAL, USER
  
  // 生成模型配置
  provider          String   // openai, deepseek, anthropic, google, custom
  model             String   // e.g. gpt-4, deepseek-v4-flash
  apiKey            String   // Encrypted
  baseUrl           String?  // Optional custom base URL
  
  // 思考模型配置
  enableThinking    Boolean  @default(false)
  thinkingProvider  String?
  thinkingModel     String?
  thinkingApiKey    String?  // Encrypted
  thinkingBaseUrl   String?
  thinkingLevel     Int      @default(3) // 1-5
  
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([scope])
}

// ✅ NEW: AI Provider Configuration
model AiProvider {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    // e.g. "DeepSeek"
  slug        String    @unique // e.g. "deepseek"
  baseUrl     String?
  apiKey      String?   // Encrypted. Optional (some providers might be public or authless?)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  models      AiModel[]
}

// ✅ NEW: AI Model Definition
model AiModel {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String     // Display name e.g. "DeepSeek V4 Flash"
  model       String     // API model string e.g. "deepseek-v4-flash"
  providerId  String     @db.ObjectId
  provider    AiProvider @relation(fields: [providerId], references: [id])
  type        String     // "generation", "thinking"

  // Configs
  maxTokens   Int        @default(2048)
  temperature Float      @default(0.7)
  timeout     Int        @default(60000) // ms

  // 高级参数 (topP / frequencyPenalty / presencePenalty / responseFormat / stop / thinking / reasoning_effort)
  // DeepSeek v4 模型使用 { thinking: { type: "enabled" }, reasoning_effort: "high" } 控制思考模式
  params      Json       @default("{}")

  // Task 26.1：每百万 tokens 单价（用于估算任务成本，null = 未配置则不估算）
  // 注：MongoDB connector 不支持 Decimal 类型，改用 Float?（精度足够用于成本估算）
  pricePerMillionTokens Float?

  // Task 26.2：模型健康度（null / 'healthy' / 'degraded' / 'down'，默认 null 视为 healthy）
  // - degraded：连续 3 次 API 错误（Task 38）
  // - down：连续 5 次 API 错误
  // - 由队列 executeJob 失败时更新，管理端可手动 reset
  healthStatus       String?
  lastHealthCheckAt  DateTime?

  isActive    Boolean    @default(true)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  preferences UserAiPreference[]
}

// ✅ NEW: User AI Preferences
model UserAiPreference {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  modelId     String   @db.ObjectId
  model       AiModel  @relation(fields: [modelId], references: [id])
  
  count       Int      @default(1)
  lastUsed    DateTime @default(now())
  isDefault   Boolean  @default(false)
  
  @@unique([userId, modelId])
  @@index([userId, lastUsed])
}

model VerificationLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  problemId String   @db.ObjectId
  problem   Problem  @relation(fields: [problemId], references: [id])
  operatorId String  @db.ObjectId // 操作人ID
  status    String   // SUCCESS, FAILED
  details   Json     // 详细报告：执行时间、修正数量、错误信息等
  createdAt DateTime @default(now())

  @@index([problemId])
}

model SystemConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// 系统公告（首页展示）
model SystemAnnouncement {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  isPinned    Boolean   @default(false)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  authorId    String    @db.ObjectId
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished, isPinned, publishedAt])
  @@index([expiresAt])
}

/* ============================================================================
 * 游戏化系统模型（Phase 1 预留，Phase 2+ 启用）
 * - ClassAssignmentProblemProgress：班级作业题目计时核心（Phase 1 启用）
 * - CoinTransaction：金币流水
 * - ShopItem / PurchaseTransaction：商城
 * - AssignmentCompletionRewardLog / ContestRankingRewardLog / ContestCompletionRewardLog：奖励日志
 * - RewardGrantLog：幂等保障表
 * - AchievementProgress：成就进度
 * - RewardConfigChangeLog：配置变更审计
 * ========================================================================== */

// 金币流水（审计用，所有金币变动都记录）
model CoinTransaction {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  source       String   // first_ac / assignment_completion / contest_ranking / contest_completion / achievement / registration / rating_improvement / level_milestone / shop_purchase / admin_adjust
  amount       Int      // 正数为获得，负数为消耗
  balanceAfter Int      // 变动后余额（快照）
  reason       String?  // 描述
  relatedId    String?  // 关联资源 ID（如题目ID/作业ID/商品ID）
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([source])
}

// 商城商品
model ShopItem {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  icon        String?
  category    String    // title / avatar_frame / theme_color / consumable
  price       Int       // 金币价格
  stock       Int?      // 库存（null=无限）
  isActive    Boolean   @default(true)
  isSystem    Boolean   @default(false)  // 系统固定物品（不可删除）
  creatorId   String?   @db.ObjectId     // 创建者ID（管理员），系统物品为 null
  creator     User?     @relation("ShopItemCreator", fields: [creatorId], references: [id])
  metadata    Json?     // 物品元数据（如称号文本、头像框URL、主题色值等）
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  purchases   PurchaseTransaction[]

  @@index([isActive, category])
  @@index([isSystem])
  @@index([creatorId])
}

// 购买交易记录
model PurchaseTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  itemId    String   @db.ObjectId
  item      ShopItem @relation(fields: [itemId], references: [id])
  pricePaid Int      // 实际支付价格（快照）
  status    String   @default("completed")  // completed / refunded
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
  @@index([userId])
}

// 班级作业题目作答进度（计时核心，Phase 1 启用）
model ClassAssignmentProblemProgress {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId  String    @db.ObjectId
  assignment    ClassAssignment @relation(fields: [assignmentId], references: [id])
  problemId     String    @db.ObjectId
  problem       Problem   @relation(fields: [problemId], references: [id])
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id])

  timeStarted    DateTime  @default(now())  // 首次打开时间
  timeElapsedMs  Int       @default(0)       // 累计用时（ms，不含暂停期间）
  lastResumedAt  DateTime?                   // 最近一次 resume 时间（null=已暂停）
  isPaused       Boolean   @default(false)   // 是否暂停中
  completedAt    DateTime?                   // 首次 AC 完成时间
  finalTimeMs    Int?                         // 完成时的最终用时（ms）

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([assignmentId, problemId, userId])
  @@index([assignmentId, userId])
  @@index([userId])
}

// 班级作业完成度奖励发放日志
model AssignmentCompletionRewardLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId  String   @db.ObjectId
  assignment    ClassAssignment @relation(fields: [assignmentId], references: [id])
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  tierIndex     Int      // 命中的层次索引
  minCompletion Float    // 该层次最低完成率
  expGranted    Int      // 实际发放经验
  coinGranted   Int      // 实际发放金币
  createdAt     DateTime @default(now())

  @@unique([assignmentId, userId, tierIndex])
  @@index([assignmentId, userId])
}

// 竞赛排名奖励发放日志
model ContestRankingRewardLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  contestId   String   @db.ObjectId
  contest     Contest  @relation(fields: [contestId], references: [id])
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  rank        Int      // 最终排名
  expGranted  Int      // 实际发放经验
  coinGranted Int      // 实际发放金币
  createdAt   DateTime @default(now())

  @@unique([contestId, userId])
  @@index([contestId, rank])
}

// 竞赛完成度奖励发放日志
model ContestCompletionRewardLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  contestId   String   @db.ObjectId
  contest     Contest  @relation(fields: [contestId], references: [id])
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  tierIndex   Int      // 命中的层次索引
  minSolved   Int      // 该层次最低解题数
  expGranted  Int      // 实际发放经验
  coinGranted Int      // 实际发放金币
  createdAt   DateTime @default(now())

  @@unique([contestId, userId, tierIndex])
  @@index([contestId, userId])
}

// 奖励发放幂等表（防重复发放）
model RewardGrantLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  source      String   // first_ac / assignment_completion / contest_ranking / contest_completion / achievement / registration / rating_improvement / level_milestone / shop_purchase
  relatedId   String?  // 关联资源 ID（题目ID/作业ID/竞赛ID/成就ID 等）
  expGranted  Int      @default(0)
  coinGranted Int      @default(0)
  status      String   @default("success")  // success / failed
  metadata    Json?
  createdAt   DateTime @default(now())

  @@unique([userId, source, relatedId])
  @@index([source, relatedId])
  @@index([status])
  @@index([userId, createdAt])
}

// 成就进度追踪
model AchievementProgress {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  userId        String      @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])
  achievementId String      @db.ObjectId
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  progress      Int         @default(0)  // 当前进度
  target        Int                      // 目标值
  updatedAt     DateTime    @updatedAt
  createdAt     DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// 奖励配置变更审计日志
model RewardConfigChangeLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  targetType  String   // problem / assignment / contest / contest_problem / assignment_problem
  targetId    String   @db.ObjectId
  field       String   // 变更字段
  oldValue    String?  // 旧值（序列化）
  newValue    String?  // 新值（序列化）
  operatorId  String   @db.ObjectId
  operator    User     @relation(fields: [operatorId], references: [id])
  createdAt   DateTime @default(now())

  @@index([targetType, targetId])
  @@index([operatorId])
}
