# MongoDB 连接字符串
DATABASE_URL=mongodb://localhost:27017/oj-platform

# JWT 密钥（必填，生产环境必须设置）
# 建议使用至少 32 个字符的随机字符串
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-secure-random-string-at-least-32-characters-long

# 运行环境: development | production
NODE_ENV=development

# 时区（建议显式设置，确保日期时间处理一致；生产环境未设置时 lib/env.ts 会 warn）
TZ=Asia/Shanghai

# 服务端口
PORT=3000

# 前端 URL（用于 CORS 配置）
FRONTEND_URL=http://localhost:3000

# Docker 部署标识（Docker 部署时自动设置）
# USE_DOCKER=true

# 评测机配置
# 超时容差比例（0.1 = 时间限制的 10%，最小 2000ms 基准）
JUDGE_EXTRA_TIME_RATIO=0.1
# 临界 TLE 重测次数（0 = 关闭重测）
JUDGE_REJUDGE_TIMES=1
# 评测并发数（CPU 密集型评测建议 1，避免 CPU 争抢导致计时不准）
JUDGE_MAX_CONCURRENT=1
# 编译超时（毫秒，默认 Windows 30000 / Linux 20000）
# Windows 下 MinGW g++ 首次启动较慢，建议保持 30000
JUDGE_COMPILE_TIMEOUT=30000
# 单任务最大评测时长（秒，默认 300），超时强制标记失败
# 大测点+重测场景可适当调高（如 30 测点 * 5s * 3 重测 = 450s，建议设 600）
JUDGE_JOB_TIMEOUT=300

# Redis 连接（可选，用于队列）
# REDIS_URL=redis://localhost:6379

# =========================================================
# AI 配置加密密钥（用于加密存储 AI 服务商的 API Key）
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =========================================================
AI_CONFIG_ENCRYPTION_KEY=

# =========================================================
# MongoDB / Redis 容器凭证（docker-compose 部署使用）
# =========================================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=
MONGO_APP_USER=ojuser
MONGO_APP_PASSWORD=
REDIS_PASSWORD=

# =========================================================
# AI 任务配置
# =========================================================
# AI 出题任务超时（毫秒，默认 5 分钟）
AI_JOB_TIMEOUT_MS=300000
# AI 题解任务超时（毫秒，默认 3 分钟）
AI_SOLUTION_TIMEOUT_MS=180000
# AI 题解并发数
AI_SOLUTION_MAX_CONCURRENT=2

# =========================================================
# 日志与前端配置
# =========================================================
# 日志级别: debug | info | warn | error
LOG_LEVEL=info
# Socket.IO 客户端连接地址（构建期必需）
NEXT_PUBLIC_API_URL=http://localhost:3000
# 站点基础 URL（sitemap.ts 使用，构建期必需）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =========================================================
# 安全配置
# =========================================================
# 受信任的反向代理层数（影响 X-Forwarded-For 解析，rate-limit 使用）
TRUSTED_PROXIES=1
# 强制 Cookie Secure 标志（非生产环境部署在 HTTPS 后时设为 true）
# FORCE_SECURE_COOKIE=true

# Windows 本地评测确认（无 Docker 时需设为 1 以显式确认安全风险）
# 仅在 USE_DOCKER=false 且 platform=win32 时需要
# ALLOW_LOCAL_JUDGE_ON_WINDOWS=1
